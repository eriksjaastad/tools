# Projects Root — set this to your machine's project root
# Laptop: ~/projects
# Mac Mini: ~/.openclaw/workspace/projects
PROJECTS_ROOT=

# Required (Go binaries) — set based on PROJECTS_ROOT
HUB_SERVER_PATH=${PROJECTS_ROOT}/_tools/claude-mcp-go/bin/claude-mcp-go
MCP_SERVER_PATH=${PROJECTS_ROOT}/_tools/ollama-mcp-go/bin/server

# Optional
HANDOFF_DIR=_handoff
FLOOR_MANAGER_ID=floor_manager
AGENT_HUB_DRY_RUN=0
DEBUG=0
LOG_LEVEL=INFO
